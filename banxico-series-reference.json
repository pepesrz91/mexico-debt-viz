{
  "metadata": {
    "source": "Banxico SIE API",
    "api_base": "https://www.banxico.org.mx/SieAPIRest/service/v1/",
    "header": "Bmx-Token",
    "unit": "Millones de Pesos (MDP), Saldos Nominales, Monthly",
    "notes": [
      "CF835 series (cartera vigente) provide TOTALS including sin/con restricción",
      "CF615 series (financiamiento detallado) break down into sin/con restricción, vigente/vencida",
      "For cartera vencida, use CF615 series (SF235xxx, SF266xxx)",
      "IMOR (Indice de Morosidad) is NOT available in Banxico SIE - it comes from CNBV",
      "To calculate IMOR: cartera_vencida / (cartera_vigente + cartera_vencida) * 100",
      "Data current through Feb 2026 as of this writing"
    ],
    "sample_api_call": "curl -s 'https://www.banxico.org.mx/SieAPIRest/service/v1/series/SF235712/datos/2024-01-01/2024-12-31' -H 'Bmx-Token: YOUR_TOKEN'"
  },

